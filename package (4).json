import { Router, type IRouter } from "express";
import { db, scanLogsTable, equipmentTable } from "@workspace/db";
import { eq, desc, lt, or, and, sql } from "drizzle-orm";
import { requireAuth } from "../middlewares/auth";

const router: IRouter = Router();

const PAGE_SIZE = 20;

router.get("/logs", requireAuth, async (req, res): Promise<void> => {
  const cursor = typeof req.query.cursor === "string" ? req.query.cursor : undefined;

  let query = db
    .select({
      id: scanLogsTable.id,
      equipmentId: scanLogsTable.equipmentId,
      status: scanLogsTable.status,
      note: scanLogsTable.note,
      photoUrl: scanLogsTable.photoUrl,
      timestamp: scanLogsTable.timestamp,
      equipmentName: equipmentTable.name,
    })
    .from(scanLogsTable)
    .innerJoin(equipmentTable, eq(scanLogsTable.equipmentId, equipmentTable.id))
    .orderBy(desc(scanLogsTable.timestamp), desc(scanLogsTable.id))
    .limit(PAGE_SIZE + 1)
    .$dynamic();

  if (cursor) {
    const parts = cursor.split("|");
    const cursorDate = new Date(parts[0]);
    const cursorId = parts[1];

    if (!isNaN(cursorDate.getTime()) && cursorId) {
      query = query.where(
        or(
          lt(scanLogsTable.timestamp, cursorDate),
          and(
            eq(scanLogsTable.timestamp, cursorDate),
            sql`${scanLogsTable.id} < ${cursorId}`,
          ),
        ),
      );
    }
  }

  const rows = await query;

  const hasMore = rows.length > PAGE_SIZE;
  const items = hasMore ? rows.slice(0, PAGE_SIZE) : rows;
  const lastItem = items[items.length - 1];
  const nextCursor = hasMore && lastItem
    ? `${lastItem.timestamp.toISOString()}|${lastItem.id}`
    : null;

  res.json({ items, nextCursor });
});

export default router;
