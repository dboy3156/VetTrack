# =============================================================================
# VetTrack Environment Variables
# Copy this file to .env and fill in all required values before running.
# Variables marked [REQUIRED] must be set in production.
# Variables marked [OPTIONAL] have defaults or are only needed for specific features.
# =============================================================================

# --- Database ---

# [REQUIRED] PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgres://vettrack:strongpassword@db.example.com:5432/vettrack
DATABASE_URL=postgres://user:password@localhost:5432/vettrack

# --- Session Security ---

# [REQUIRED] A long, random secret used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: Never use the default value in production.
SESSION_SECRET=replace-with-a-long-random-string

# --- Clerk Authentication ---

# [REQUIRED] Clerk secret key (server-side). Starts with sk_live_ or sk_test_.
# Find in Clerk Dashboard > API Keys.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Clerk publishable key (used by the Vite frontend). Starts with pk_live_ or pk_test_.
# Must be prefixed with VITE_ so Vite exposes it to the browser bundle.
# Find in Clerk Dashboard > API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# --- VAPID Keys (Web Push Notifications) ---

# [OPTIONAL] VAPID public key for web push. If not set, keys are auto-generated
# and stored in the database on first startup.
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=

# [OPTIONAL] VAPID private key for web push. Must be paired with VAPID_PUBLIC_KEY.
VAPID_PRIVATE_KEY=

# [OPTIONAL] Client-exposed VAPID public key for push subscriptions.
# This should match VAPID_PUBLIC_KEY.
VITE_VAPID_PUBLIC_KEY=

# --- Admin Access ---

# [OPTIONAL] Comma-separated list of email addresses that are automatically
# granted admin role when they sign in via Clerk.
# Example: admin@example.com,ops@example.com
ADMIN_EMAILS=

# --- Phase 2.2 service-task domain (optional) ---

# [OPTIONAL] When true, enables service-task adapter + audit logging for users in the rollout cohort.
# Deploy with false; enable in staging/production gradually. Rollback: set false and SERVICE_TASK_MODE_PERCENT=0.
# ENABLE_SERVICE_TASK_MODE=false

# [OPTIONAL] 0–100. Percentage of users (deterministic by user id) that receive service-task mode when ENABLE_SERVICE_TASK_MODE=true.
# SERVICE_TASK_MODE_PERCENT=0

# [OPTIONAL] Non-production only. When true, if Clerk session has no org id, clinic may be resolved from an existing DB user row.
# Ignored when NODE_ENV=production (fail-closed). Production must use Clerk Organizations + valid clinic on user rows.
# ALLOW_DB_CLINIC_FALLBACK=false

# --- Server ---

# [OPTIONAL] Port the API server listens on. Defaults to 3001.
PORT=3001

# [OPTIONAL] Node environment. Set to "production" for production deployments.
NODE_ENV=development

# [OPTIONAL] When true/1, shortens scheduler intervals and treats "expected return minutes"
# as seconds for local testing. Leave unset or false in production and demos.
# TEST_MODE=false

# --- CORS ---

# [OPTIONAL] Explicit allowed origin for CORS requests.
# Required in production if your frontend is on a different domain.
# Example: https://vettrack.example.com
ALLOWED_ORIGIN=

# --- Sentry Error Tracking ---

# [OPTIONAL] Sentry DSN for server-side error reporting. Leave blank to disable.
# Find in Sentry Dashboard > Project Settings > Client Keys (DSN).
SENTRY_DSN=

# [OPTIONAL] Sentry DSN for frontend (browser) error reporting.
# Must be prefixed with VITE_ so Vite exposes it to the browser bundle.
# Can be the same DSN as SENTRY_DSN, or a separate Sentry project.
VITE_SENTRY_DSN=

# --- WhatsApp Alerts ---

# [OPTIONAL] Default WhatsApp number for equipment alerts (E.164 format).
# Example: +15550001234
WHATSAPP_DEFAULT_PHONE=

# --- WebSocket (Real-time) ---

# [OPTIONAL] WebSocket URL for real-time equipment updates.
# Format: wss://your-api.example.com/ws (production) or ws://localhost:3001/ws (local)
# Leave blank to disable real-time sync (app will fall back to polling).
VITE_WS_URL=wss://your-api/ws

# --- Replit Dev Environment (auto-set by Replit, do not set manually) ---

# [OPTIONAL] Replit dev domain — used to configure CORS in development.
# Automatically set by Replit. You do not need to set this.
# REPLIT_DEV_DOMAIN=
