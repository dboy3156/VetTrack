{
  "name": "vettrack",
  "version": "1.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "fuser -k 3001/tcp 5000/tcp 2>/dev/null; true",
    "dev": "concurrently -k -p \"[{name}]\" -n \"api,web\" -c \"cyan,teal\" \"tsx watch server/index.ts\" \"vite --port 5000 --host\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "validate:prod": "tsx scripts/validate-prod.ts",
    "test": "node tests/basic.test.js && node tests/route-registration.test.js && node tests/concurrency.test.js && node tests/offline.test.js && node tests/conflict.test.js && node tests/pwa.system.test.js && tsx tests/i18n-hardening.test.ts && tsx tests/auth-hardening.test.ts && node tests/multi-tenancy-hardening.test.js && node tests/no-hardcoded-ui-strings.test.js",
    "test:signup": "playwright test tests/signup-flow.spec.ts --reporter=list",
    "db:migrate": "drizzle-kit migrate",
    "demo:hospital:seed": "tsx server/demo-production-safe/simulate-hospital-demo.ts",
    "demo:hospital:rollback": "tsx server/demo-production-safe/rollback-hospital-demo.ts"
  },
