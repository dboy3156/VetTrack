/**
 * Returns scan logs across all equipment, most recent first, with cursor-based pagination.
 * @summary Global activity feed
 */
export const getListLogsUrl = (params?: ListLogsParams) => {
  const normalizedParams = new URLSearchParams();

  Object.entries(params || {}).forEach(([key, value]) => {
    if (value !== undefined) {
      normalizedParams.append(key, value === null ? "null" : value.toString());
    }
  });

  const stringifiedParams = normalizedParams.toString();

  return stringifiedParams.length > 0
    ? `/api/logs?${stringifiedParams}`
    : `/api/logs`;
};

export const listLogs = async (
  params?: ListLogsParams,
  options?: RequestInit,
): Promise<ActivityFeed> => {
  return customFetch<ActivityFeed>(getListLogsUrl(params), {
