# =============================================================================
# VetTrack — production environment
# Vite loads this for `pnpm build` (embeds VITE_* into the client bundle).
# For secrets, prefer `.env.production.local` (gitignored) — same keys, overrides this file.
# Server runtime: set these in the host environment or use a merged `.env` on the server.
# =============================================================================

NODE_ENV=production

# --- Database [REQUIRED] ---
DATABASE_URL=postgresql://postgres:BkNzNBwhZcuHnGkEmcjgOgywzmDRtcdi@mainline.proxy.rlwy.net:34576/railway

# --- Session [REQUIRED] ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=8183c275649f50b242b024c2da16e8db4dafab8b08c96052aa0a84b21cc905bb4a0e7b5d21fbad76a73291a259285925f8cbdade06c33805b05539d8697fbaa8
# --- Clerk [REQUIRED] ---
# Same Clerk application: secret on server, publishable in the browser bundle.
CLERK_SECRET_KEY=sk_live_5KYn1dNiZjactr3jHEfy5vW8q42G5doqkZfkgjK1Rf
VITE_CLERK_PUBLISHABLE_KEY=REPLACE_ME_pk_live

# --- CORS [REQUIRED for deploy.sh / API] ---
ALLOWED_ORIGIN=https://vettrack.uk

# --- Server ---
PORT=3001

# --- Admin bootstrap (optional) ---
