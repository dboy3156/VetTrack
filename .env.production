# --- Clinic / tenant fallback (optional; default is on) ---
ALLOW_DB_CLINIC_FALLBACK=true

# --- Client-only (Vite; safe to be public) ---
# Sentry browser DSN (optional)
# VITE_SENTRY_DSN=

# WebSocket URL for realtime (optional; leave unset to disable)
# VITE_WS_URL=wss://vettrack.uk/ws

# Push notifications — public key only (optional; must match server VAPID_PUBLIC_KEY)
# VITE_VAPID_PUBLIC_KEY=
