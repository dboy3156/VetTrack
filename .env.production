# =============================================================================
# VetTrack — production environment
# Vite loads this for `pnpm build` (embeds VITE_* into the client bundle).
# For secrets, prefer `.env.production.local` (gitignored) — same keys, overrides this file.
# Server runtime: set these in the host environment or use a merged `.env` on the server.
# =============================================================================

NODE_ENV=production

# --- Database [REQUIRED] ---
DATABASE_URL=REPLACE_ME_postgres_url

# --- Session [REQUIRED] ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_ME_long_random_hex

# --- Clerk [REQUIRED] ---
# Same Clerk application: secret on server, publishable in the browser bundle.
CLERK_SECRET_KEY=REPLACE_ME_sk_live
VITE_CLERK_PUBLISHABLE_KEY=REPLACE_ME_pk_live

# --- CORS [REQUIRED for deploy.sh / API] ---
ALLOWED_ORIGIN=https://vettrack.uk

# --- Server ---
PORT=3001

# --- Admin bootstrap (optional) ---
# ADMIN_EMAILS=you@example.com

# --- Clinic / tenant fallback (optional; default is on) ---
# DB_CLINIC_FALLBACK=true

# --- Client-only (Vite; safe to be public) ---
# Sentry browser DSN (optional)
# VITE_SENTRY_DSN=

# WebSocket URL for realtime (optional; leave unset to disable)
# VITE_WS_URL=wss://vettrack.uk/ws

# Push notifications — public key only (optional; must match server VAPID_PUBLIC_KEY)
# VITE_VAPID_PUBLIC_KEY=
