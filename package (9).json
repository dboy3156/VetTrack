import { useState, useMemo } from "react";
import { Layout } from "@/components/layout";
import { useListLogs } from "@/lib/api";
import { Link } from "wouter";
import { ArrowLeft, CheckCircle2, AlertTriangle, Wrench, ChevronRight, MessageSquare, Loader2, Sparkles } from "lucide-react";
import { formatDistanceToNow, format, parseISO } from "date-fns";

const STATUS_CONFIG: Record<string, { icon: typeof CheckCircle2; color: string; bg: string; label: string }> = {
  ok: { icon: CheckCircle2, color: "text-green-600", bg: "bg-green-100", label: "OK" },
  issue: { icon: AlertTriangle, color: "text-orange-600", bg: "bg-orange-100", label: "Issue" },
  maintenance: { icon: Wrench, color: "text-blue-600", bg: "bg-blue-100", label: "Maintenance" },
  sterilized: { icon: Sparkles, color: "text-teal-600", bg: "bg-teal-100", label: "Sterilized" },
};

type FeedItem = {
  id: string;
  equipmentId: string;
  equipmentName: string;
  status: string;
  note?: string | null;
  photoUrl?: string | null;
  timestamp: string;
};

export default function Activity() {
  const [cursors, setCursors] = useState<string[]>([]);

  const pages = [undefined, ...cursors];

  return (
    <Layout>
      <div className="flex flex-col gap-4 pb-10">
        <div>
          <Link href="/" className="inline-flex items-center text-base text-muted-foreground hover:text-foreground mb-3 transition-colors">
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Link>
          <h1 className="text-2xl sm:text-3xl font-bold tracking-tight text-foreground">Activity</h1>
          <p className="text-base text-muted-foreground mt-0.5">Recent scan events across all equipment</p>
        </div>

        {pages.map((cursor, pageIndex) => (
          <ActivityPage
            key={cursor ?? "__first__"}
            cursor={cursor}
            isLast={pageIndex === pages.length - 1}
            onLoadMore={(nextCursor: string) => {
              setCursors((prev) => [...prev, nextCursor]);
            }}
          />
        ))}
      </div>
    </Layout>
  );
}

function ActivityPage({
  cursor,
  isLast,
  onLoadMore,
}: {
  cursor: string | undefined;
  isLast: boolean;
  onLoadMore: (nextCursor: string) => void;
}) {
  const { data, isLoading, isError, refetch } = useListLogs(
    cursor ? { cursor } : undefined,
  );

  const items: FeedItem[] = useMemo(() => data?.items ?? [], [data]);
  const hasMore = isLast && data?.nextCursor != null;

  if (isLoading) {
    return (
      <div className="flex items-center justify-center py-10">
        <Loader2 className="w-6 h-6 animate-spin text-muted-foreground" />
      </div>
    );
  }

  if (isError) {
    return (
      <div className="text-center py-10">
        <p className="text-sm text-muted-foreground mb-3">Failed to load activity</p>
        <button
          onClick={() => refetch()}
          className="px-4 py-2 rounded-xl bg-muted text-sm font-semibold text-foreground hover:bg-muted/80 transition-colors"
        >
          Retry
        </button>
      </div>
    );
  }

  if (items.length === 0 && !cursor) {
    return (
      <div className="text-center py-20 text-muted-foreground">
        No scan activity yet. Scan some equipment to see events here.
      </div>
    );
  }

  return (
    <>
      <div className="flex flex-col gap-2">
        {items.map((item) => {
          const cfg = STATUS_CONFIG[item.status] ?? STATUS_CONFIG.ok;
          const Icon = cfg.icon;
          const ts = parseISO(item.timestamp);

          return (
            <Link
              key={item.id}
              href={`/equipment/${item.equipmentId}`}
              className="flex items-start gap-3 p-3 bg-card border border-border rounded-xl hover:bg-muted/50 transition-colors group"
            >
              <div className={`mt-0.5 flex-shrink-0 w-8 h-8 rounded-full ${cfg.bg} flex items-center justify-center`}>
                <Icon className={`w-4 h-4 ${cfg.color}`} />
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-start justify-between gap-2">
                  <div className="min-w-0">
                    <p className="text-sm font-semibold text-foreground truncate">{item.equipmentName}</p>
                    <p className="text-xs text-muted-foreground mt-0.5">
                      <span className={`font-medium ${cfg.color}`}>{cfg.label}</span>
                      {" · "}
                      <span title={format(ts, "PPpp")}>{formatDistanceToNow(ts, { addSuffix: true })}</span>
                    </p>
                  </div>
                  <ChevronRight className="w-4 h-4 text-muted-foreground/50 group-hover:text-foreground flex-shrink-0 mt-1 transition-colors" />
                </div>
                {item.note && (
                  <div className="mt-1.5 flex items-start gap-1.5 text-xs text-muted-foreground">
                    <MessageSquare className="w-3 h-3 mt-0.5 flex-shrink-0" />
                    <span className="line-clamp-2">{item.note}</span>
                  </div>
                )}
              </div>
            </Link>
          );
        })}
      </div>

      {hasMore && (
        <button
          onClick={() => onLoadMore(data!.nextCursor!)}
          className="mx-auto flex items-center gap-2 px-5 py-2.5 rounded-xl bg-muted text-sm font-semibold text-foreground hover:bg-muted/80 transition-colors"
        >
          Load more
        </button>
      )}
    </>
  );
}
